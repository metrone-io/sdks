{
  "name": "@metrone-io/mcp",
  "version": "1.0.0",
  "description": "Metrone MCP server — expose analytics to AI agents via Model Context Protocol",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "metrone-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
