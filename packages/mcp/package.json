    "mcp",
    "model-context-protocol",
    "analytics",
    "ai-agents"
  ],
  "author": "Metrone",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/metrone-io/sdks.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/metrone-io/sdks/issues"
  },
  "homepage": "https://metrone.io",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.2"
  }
}
