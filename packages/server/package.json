{
  "name": "@metrone-io/server",
  "version": "1.0.0",
  "description": "Metrone server-side SDK for Node.js, Deno, Bun, and edge runtimes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "metrone",
    "analytics",
    "server",
    "ai-agent",
    "privacy",
    "tracking",
    "node",
    "deno",
    "bun",
    "edge"
  ],
  "author": "Metrone",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/metrone-io/sdks.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/metrone-io/sdks/issues"
  },
  "homepage": "https://metrone.io",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "tsup": "^8.0.0",
    "typescript": "^5.3.2",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
