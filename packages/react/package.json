{
  "name": "@metrone-io/react",
  "version": "1.1.0",
  "description": "Metrone React integration - Privacy-first analytics for React",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "dev": "rollup -c -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "analytics",
    "privacy",
    "first-party",
    "react",
    "metrone",
    "tracking"
  ],
  "author": "Metrone",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/metrone-io/sdks.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/metrone-io/sdks/issues"
  },
  "homepage": "https://metrone.io",
  "engines": {
    "node": ">=16.0.0"
  },
  "peerDependencies": {
    "@metrone-io/sdk": "^1.0.0",
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/jest": "^29.5.8",
    "@types/react": "^18.2.37",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "react": "^18.2.0",
    "rimraf": "^5.0.5",
    "rollup": "^4.6.1",
    "rollup-plugin-terser": "^7.0.2",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
